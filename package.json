    "start": "node dist/server.cjs",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv": "^17.4.2",
